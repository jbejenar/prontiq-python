# Prontiq Platform — Environment Variables
# Copy to .env.local and fill in values

# AWS (handled by SST in dev, OIDC in CI)
AWS_REGION=ap-southeast-2

# Webhook secrets (for packages/webhooks/ handlers — enabled in P1B)
# Only required when the corresponding webhook route is live.
CLERK_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Server-side API credentials (planned — P1B)
# Only required when the provisioning chain is wired up.
STRIPE_SECRET_KEY=sk_test_...

# Lago billing-event forwarding (P1B.16; required for deployed stages)
# The producer remains gated by BILLING_EVENTS_ENABLED until Lago metrics,
# canonical orgs, and replay verification are complete.
LAGO_API_URL=https://billing-dev.prontiq.dev
LAGO_API_KEY=lago_...
BILLING_EVENTS_ENABLED=false

# OpenSearch
OPENSEARCH_ENDPOINT=https://search-flat-white-xxx.ap-southeast-2.es.amazonaws.com
