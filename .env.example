# Prontiq Platform — Environment Variables
# Copy to .env.local and fill in values

# AWS (handled by SST in dev, OIDC in CI)
AWS_REGION=ap-southeast-2

# Webhook secrets (for packages/webhooks/ handlers — enabled in P1B)
# Only required when the corresponding webhook route is live.
CLERK_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Server-side API credentials (planned — P1B)
# Only required when the provisioning chain is wired up.
STRIPE_SECRET_KEY=sk_test_...

# OpenSearch
OPENSEARCH_ENDPOINT=https://search-flat-white-xxx.ap-southeast-2.es.amazonaws.com
