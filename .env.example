# Prontiq Platform — Environment Variables
# Copy to .env.local and fill in values

# AWS (handled by SST in dev, OIDC in CI)
AWS_REGION=ap-southeast-2

# Webhook secrets (for packages/webhooks/ handlers)
# Only required when the corresponding webhook route is live.
CLERK_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...
LAGO_WEBHOOK_HMAC_SECRET=

# Legacy Stripe runtime rollback.
# STRIPE_SECRET_KEY is only required while LEGACY_STRIPE_RUNTIME_ENABLED=true.
STRIPE_SECRET_KEY=
LEGACY_STRIPE_RUNTIME_ENABLED=false

# Lago billing and usage forwarding (required for deployed stages)
LAGO_API_URL=https://billing-dev.prontiq.dev
LAGO_API_KEY=
LAGO_PAYMENT_PROVIDER_CODE=stripe-main
BILLING_EVENTS_ENABLED=true
LAGO_WEBHOOK_RECONCILIATION_ENABLED=true
COUNTER_PERIOD_SOURCE=lago

# OpenSearch
OPENSEARCH_ENDPOINT=https://search-flat-white-xxx.ap-southeast-2.es.amazonaws.com
