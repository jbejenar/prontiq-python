{
  "Statement": [
    {
      "Action": [
        "s3:CreateBucket",
        "s3:PutObject",
        "s3:PutObjectTagging",
        "s3:GetObject",
        "s3:GetObjectTagging",
        "s3:DeleteObject",
        "s3:DeleteObjectTagging",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:PutBucketPolicy",
        "s3:GetBucketPolicy",
        "s3:PutBucketVersioning",
        "s3:PutEncryptionConfiguration",
        "s3:GetEncryptionConfiguration",
        "s3:PutBucketPublicAccessBlock",
        "s3:PutLifecycleConfiguration",
        "dynamodb:CreateTable",
        "dynamodb:DescribeTable",
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:DeleteItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteTable",
        "dynamodb:UpdateTable",
        "dynamodb:TagResource",
        "dynamodb:UntagResource",
        "dynamodb:ListTagsOfResource",
        "dynamodb:UpdateTimeToLive",
        "dynamodb:DescribeTimeToLive",
        "dynamodb:UpdateContinuousBackups",
        "dynamodb:DescribeContinuousBackups"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "SSTBootstrapAndPulumiState"
    },
    {
      "Action": [
        "lambda:*"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "LambdaManagement"
    },
    {
      "Action": [
        "apigateway:*"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "APIGateway"
    },
    {
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:PassRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy",
        "iam:TagRole",
        "iam:CreateServiceLinkedRole"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "IAMPassRole"
    },
    {
      "Action": [
        "logs:*",
        "cloudwatch:*",
        "xray:*"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "CloudWatch"
    },
    {
      "Action": [
        "es:ESHttp*",
        "es:DescribeElasticsearchDomain",
        "es:DescribeDomain"
      ],
      "Effect": "Allow",
      "Resource": "arn:aws:es:ap-southeast-2:493712557159:domain/flat-white/*",
      "Sid": "OpenSearch"
    },
    {
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Effect": "Allow",
      "Resource": [
        "arn:aws:s3:::flat-white-address-493712557159-ap-southeast-2-an",
        "arn:aws:s3:::flat-white-address-493712557159-ap-southeast-2-an/*"
      ],
      "Sid": "DataBucketAccess"
    },
    {
      "Action": [
        "wafv2:*"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "WAF"
    },
    {
      "Action": [
        "events:*",
        "states:*",
        "sns:*",
        "sqs:*"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "EventBridgeAndStepFunctions"
    },
    {
      "Action": [
        "ssm:GetParameter",
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:GetParametersByPath"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "SSM"
    },
    {
      "Action": [
        "cloudfront:*"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "CloudFrontForNextjs"
    },
    {
      "Action": [
        "ecr:*"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "ECRForDockerImages"
    },
    {
      "Action": [
        "sts:GetCallerIdentity",
        "sts:AssumeRole"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "STSForPulumi"
    },
    {
      "Action": [
        "ecs:*"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "ECSForFargate"
    },
    {
      "Action": [
        "ec2:DescribeVpcs",
        "ec2:DescribeVpcAttribute",
        "ec2:DescribeSubnets",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeNetworkInterfaces",
        "ec2:CreateNetworkInterface",
        "ec2:DeleteNetworkInterface",
        "ec2:DescribeRouteTables"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "EC2DescribeForVPC"
    }
  ],
  "Version": "2012-10-17"
}
