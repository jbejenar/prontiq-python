{
  "Statement": [
    {
      "Action": ["s3:ListAllMyBuckets", "s3:GetAccountPublicAccessBlock"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "S3AccountLevelReadOnly"
    },
    {
      "Action": [
        "s3:CreateBucket",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketPolicy",
        "s3:PutBucketPolicy",
        "s3:PutBucketVersioning",
        "s3:GetEncryptionConfiguration",
        "s3:PutEncryptionConfiguration",
        "s3:PutBucketPublicAccessBlock",
        "s3:PutLifecycleConfiguration"
      ],
      "Effect": "Allow",
      "Resource": [
        "arn:aws:s3:::sst-state-*",
        "arn:aws:s3:::sst-asset-*",
        "arn:aws:s3:::prontiq-*-pqportalassetsbucket-*"
      ],
      "Sid": "S3InfraBucketManagement"
    },
    {
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:PutObjectTagging",
        "s3:GetObjectTagging",
        "s3:DeleteObjectTagging"
      ],
      "Effect": "Allow",
      "Resource": [
        "arn:aws:s3:::sst-state-*/*",
        "arn:aws:s3:::sst-asset-*/*",
        "arn:aws:s3:::prontiq-*-pqportalassetsbucket-*/*"
      ],
      "Sid": "S3InfraObjectManagement"
    },
    {
      "Action": [
        "dynamodb:CreateTable",
        "dynamodb:DescribeTable",
        "dynamodb:UpdateTable",
        "dynamodb:DeleteTable",
        "dynamodb:TagResource",
        "dynamodb:UntagResource",
        "dynamodb:ListTagsOfResource",
        "dynamodb:UpdateTimeToLive",
        "dynamodb:DescribeTimeToLive",
        "dynamodb:UpdateContinuousBackups",
        "dynamodb:DescribeContinuousBackups"
      ],
      "Effect": "Allow",
      "Resource": [
        "arn:aws:dynamodb:*:*:table/prontiq-*-PqKeysTable-*",
        "arn:aws:dynamodb:*:*:table/prontiq-*-PqPortalRevalidationTable-*",
        "arn:aws:dynamodb:*:*:table/prontiq-keys",
        "arn:aws:dynamodb:*:*:table/prontiq-keys-*",
        "arn:aws:dynamodb:*:*:table/prontiq-usage",
        "arn:aws:dynamodb:*:*:table/prontiq-usage-*",
        "arn:aws:dynamodb:*:*:table/prontiq-audit",
        "arn:aws:dynamodb:*:*:table/prontiq-audit-*",
        "arn:aws:dynamodb:*:*:table/prontiq-billing-event-deliveries",
        "arn:aws:dynamodb:*:*:table/prontiq-billing-event-deliveries-*",
        "arn:aws:dynamodb:*:*:table/prontiq-lago-webhook-events",
        "arn:aws:dynamodb:*:*:table/prontiq-lago-webhook-events-*",
        "arn:aws:dynamodb:*:*:table/prontiq-customers",
        "arn:aws:dynamodb:*:*:table/prontiq-customers-*",
        "arn:aws:dynamodb:*:*:table/prontiq-ses-suppressions",
        "arn:aws:dynamodb:*:*:table/prontiq-ses-suppressions-*"
      ],
      "Sid": "DynamoDBInfraTableManagement"
    },
    {
      "Action": ["lambda:*"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "LambdaManagement"
    },
    {
      "Action": ["apigateway:*"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "APIGateway"
    },
    {
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:PassRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy",
        "iam:ListRolePolicies",
        "iam:TagRole",
        "iam:ListRoleTags",
        "iam:CreateServiceLinkedRole"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "IAMPassRole"
    },
    {
      "Action": ["logs:*", "cloudwatch:*", "xray:*"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "CloudWatch"
    },
    {
      "Action": ["es:ESHttp*", "es:Describe*", "es:ListTags"],
      "Effect": "Allow",
      "Resource": [
        "arn:aws:es:ap-southeast-2:493712557159:domain/flat-white",
        "arn:aws:es:ap-southeast-2:493712557159:domain/flat-white/*"
      ],
      "Sid": "OpenSearch"
    },
    {
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Effect": "Allow",
      "Resource": [
        "arn:aws:s3:::flat-white-address-493712557159-ap-southeast-2-an",
        "arn:aws:s3:::flat-white-address-493712557159-ap-southeast-2-an/*"
      ],
      "Sid": "DataBucketAccess"
    },
    {
      "Action": ["wafv2:*"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "WAF"
    },
    {
      "Action": ["events:*", "states:*", "sns:*", "sqs:*"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "EventBridgeAndStepFunctions"
    },
    {
      "Action": ["ses:GetEmailIdentity", "ses:PutEmailIdentityMailFromAttributes"],
      "Effect": "Allow",
      "Resource": "arn:aws:ses:ap-southeast-2:493712557159:identity/prontiq.dev",
      "Sid": "SESMailFromManagement"
    },
    {
      "Action": [
        "ssm:GetParameter",
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:GetParametersByPath"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "SSM"
    },
    {
      "Action": ["cloudfront:*"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "CloudFrontForNextjs"
    },
    {
      "Action": ["ecr:*"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "ECRForDockerImages"
    },
    {
      "Action": ["sts:GetCallerIdentity", "sts:AssumeRole"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "STSForPulumi"
    },
    {
      "Action": ["ecs:*"],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "ECSForFargate"
    },
    {
      "Action": [
        "ec2:DescribeVpcs",
        "ec2:DescribeVpcAttribute",
        "ec2:DescribeSubnets",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeNetworkInterfaces",
        "ec2:CreateNetworkInterface",
        "ec2:DeleteNetworkInterface",
        "ec2:DescribeRouteTables"
      ],
      "Effect": "Allow",
      "Resource": "*",
      "Sid": "EC2DescribeForVPC"
    }
  ],
  "Version": "2012-10-17"
}
