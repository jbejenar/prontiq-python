{
    "openapi": "3.1.0",
    "info": {
        "title": "Prontiq Private Account API",
        "version": "1.0.0",
        "description": "Private Clerk-authenticated account and console API contracts."
    },
    "components": {
        "securitySchemes": {
            "ClerkJwt": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "Clerk session token; sent as `Authorization: Bearer <jwt>`."
            }
        },
        "schemas": {},
        "parameters": {}
    },
    "paths": {
        "/v1/account/setup": {
            "post": {
                "summary": "Recover or initialise an org envelope (Clerk JWT auth)",
                "description": "Idempotent. Resolves the caller's verified primary email via the Clerk Backend API and provisions the org envelope. The Clerk org id is the active Prontiq and Lago customer identity; Stripe remains only Lago's payment rail.",
                "security": [
                    {
                        "ClerkJwt": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Org envelope already provisioned (replay-safe)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "enum": [
                                                "created",
                                                "already_exists"
                                            ]
                                        },
                                        "orgId": {
                                            "type": "string",
                                            "description": "Clerk organization id and active Prontiq/Lago customer identity."
                                        },
                                        "emailSent": {
                                            "type": "boolean",
                                            "description": "True only when the welcome email was best-effort sent for a freshly-created envelope. Absent on already_exists replays."
                                        }
                                    },
                                    "required": [
                                        "status",
                                        "orgId"
                                    ]
                                }
                            }
                        }
                    },
                    "201": {
                        "description": "Org envelope freshly created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "enum": [
                                                "created",
                                                "already_exists"
                                            ]
                                        },
                                        "orgId": {
                                            "type": "string",
                                            "description": "Clerk organization id and active Prontiq/Lago customer identity."
                                        },
                                        "emailSent": {
                                            "type": "boolean",
                                            "description": "True only when the welcome email was best-effort sent for a freshly-created envelope. Absent on already_exists replays."
                                        }
                                    },
                                    "required": [
                                        "status",
                                        "orgId"
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "JWT missing org_id claim (NO_ACTIVE_ORG)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Missing/invalid/expired JWT",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Fatal failure — operator-facing fix required",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Retryable failure — Lago/Clerk/DDB transient",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/account/keys/create": {
            "post": {
                "summary": "Create a new API key (admin only)",
                "description": "Mints a fresh `pq_live_*` key, stores its hash, and returns the raw value once. The raw key is never persisted, never logged, and cannot be retrieved later. Free-tier orgs are capped per `PLANS[tier].maxKeys`; the cap is enforced atomically.",
                "security": [
                    {
                        "ClerkJwt": []
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "label": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 64,
                                        "description": "User-supplied display label for the key. Optional. 1-64 chars."
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Key created. Raw value returned once.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "keyId": {
                                            "type": "string",
                                            "description": "Stable identifier (`key_<ulid>`) that survives rotation."
                                        },
                                        "raw": {
                                            "type": "string",
                                            "description": "The raw key. Returned ONCE in this response and never again. Treat as a credential."
                                        },
                                        "keyPrefix": {
                                            "type": "string",
                                            "description": "Public-safe prefix for display in masked-key tables."
                                        },
                                        "createdAt": {
                                            "type": "string",
                                            "description": "ISO-8601 creation timestamp."
                                        },
                                        "label": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "keyId",
                                        "raw",
                                        "keyPrefix",
                                        "createdAt"
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request body",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Missing/invalid JWT",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "INSUFFICIENT_ROLE (non-admin) or KEY_LIMIT_EXCEEDED",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "ORG_NOT_PROVISIONED — call /v1/account/setup",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "integer"
                                                },
                                                "request_id": {
                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/account/keys": {
            "get": {
                "summary": "List active keys for the caller's org (member-allowed)",
                "description": "Returns active keys with masked prefix only. The org envelope is excluded by sentinel filter; revoked keys are excluded by the active flag.",
                "security": [
                    {
                        "ClerkJwt": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Active keys for this org",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "keys": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "keyId": {
                                                        "type": "string"
                                                    },
                                                    "keyPrefix": {
                                                        "type": "string"
                                                    },
                                                    "label": {
                                                        "type": "string"
                                                    },
                                                    "createdAt": {
                                                        "type": "string"
                                                    },
                                                    "lastUsedAt": {
                                                        "type": [
                                                            "string",
                                                            "null"
                                                        ]
                                                    },
                                                    "active": {
                                                        "type": "boolean"
                                                    },
                                                    "products": {
                                                        "type": "array",
                                                        "items": {
                                                            "type": "string"
                                                        }
                                                    }
                                                },
                                                "required": [
                                                    "keyId",
                                                    "keyPrefix",
                                                    "createdAt",
                                                    "lastUsedAt",
                                                    "active",
                                                    "products"
                                                ]
                                            }
                                        }
                                    },
                                    "required": [
                                        "keys"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Missing/invalid JWT",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "object",
                                            "properties": {
                                                "code": {
                                                    "type": "string"
                                                },
                                                "message": {
