                                                    "type": "string"
                                                },
                                                "details": {
                                                    "type": "object",
                                                    "additionalProperties": {}
                                                }
                                            },
                                            "required": [
                                                "code",
                                                "message",
                                                "status",
                                                "request_id"
                                            ]
