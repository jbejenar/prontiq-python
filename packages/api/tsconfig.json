{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@prontiq/control-plane": ["../control-plane/src/index.ts"],
      "@prontiq/control-plane/*": ["../control-plane/src/*"],
      "@prontiq/observability": ["../observability/src/index.ts"],
      "@prontiq/observability/*": ["../observability/src/*"],
      "@prontiq/shared": ["../shared/src/index.ts"],
      "@prontiq/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../shared" }, { "path": "../control-plane" }, { "path": "../observability" }]
}
