{
  "name": "@prontiq/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "pnpm -w build --filter @prontiq/api... && node --test dist/search/queries.test.js dist/scripts/migrate-api-keys.test.js",
    "test:integration": "pnpm -w build --filter @prontiq/api... && node --test dist/search/queries.integration.test.js dist/middleware/auth.integration.test.js dist/middleware/redirect-gsi.integration.test.js",
    "smoke": "pnpm -w build --filter @prontiq/api... && node dist/scripts/smoke-test.js",
    "smoke:prod": "pnpm -w build --filter @prontiq/api... && PRONTIQ_API=https://api.prontiq.dev node dist/scripts/smoke-test.js",
    "migrate:api-keys": "pnpm -w build --filter @prontiq/api... && node dist/scripts/migrate-api-keys.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-openapi": "^1.2.4",
    "@opensearch-project/opensearch": "^3.2.0",
    "@prontiq/shared": "workspace:*",
    "hono": "^4.7.0",
    "zod": "^4.3.6"
  }
}
