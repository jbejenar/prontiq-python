    "lint": "eslint src/",
    "clean": "node ../../../scripts/ts-package-build.mjs clean"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "jsdom": "^26.1.0",
    "@types/node": "^25.6.0"
  }
}
