{
  "name": "@prontiq/web-component",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/ts-package-build.mjs build",
    "typecheck": "tsc --noEmit",
