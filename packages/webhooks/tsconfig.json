{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "paths": {
      "@prontiq/control-plane": ["../control-plane/dist/index.d.ts"],
      "@prontiq/control-plane/*": ["../control-plane/dist/*"],
      "@prontiq/shared": ["../shared/dist/index.d.ts"],
      "@prontiq/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../shared" },
    { "path": "../control-plane" }
  ]
}
