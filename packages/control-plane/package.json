{
  "name": "@prontiq/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./provisioning": {
      "import": "./dist/provisioning.js",
      "types": "./dist/provisioning.d.ts"
    },
    "./audit": {
      "import": "./dist/audit.js",
      "types": "./dist/audit.d.ts"
    }
  },
  "scripts": {
    "build": "node ../../scripts/ts-package-build.mjs build",
    "typecheck": "tsc --noEmit",
    "test": "pnpm -w build --filter @prontiq/control-plane... && node --test dist/audit.test.js dist/provisioning.test.js",
    "test:integration": "pnpm -w build --filter @prontiq/control-plane... && node --test dist/provisioning.integration.test.js",
    "lint": "eslint src/",
    "clean": "node ../../scripts/ts-package-build.mjs clean"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1030.0",
    "@prontiq/shared": "workspace:*",
    "stripe": "^22.0.1",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
