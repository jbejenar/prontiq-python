{
  "name": "@prontiq/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./provisioning": {
      "import": "./dist/provisioning.js",
      "types": "./dist/provisioning.d.ts"
    },
    "./audit": {
      "import": "./dist/audit.js",
      "types": "./dist/audit.d.ts"
    },
    "./clerk": {
      "import": "./dist/clerk.js",
      "types": "./dist/clerk.d.ts"
    },
    "./lago-webhook-reconciliation": {
      "import": "./dist/lago-webhook-reconciliation.js",
      "types": "./dist/lago-webhook-reconciliation.d.ts"
    },
    "./commercial-identity-repair": {
      "import": "./dist/commercial-identity-repair.js",
      "types": "./dist/commercial-identity-repair.d.ts"
    },
    "./key-management": {
      "import": "./dist/key-management.js",
      "types": "./dist/key-management.d.ts"
    }
  },
  "scripts": {
    "build": "node ../../scripts/ts-package-build.mjs build",
    "typecheck": "node ../../scripts/ts-package-build.mjs typecheck",
    "test": "pnpm -w build --filter @prontiq/control-plane... && node --test dist/audit.test.js dist/email.test.js dist/ses-feedback.test.js dist/provisioning.test.js dist/clerk.test.js dist/lago-event-forwarder.test.js dist/lago-webhook-reconciliation.test.js dist/lago-live-smoke.test.js dist/commercial-identity-repair.test.js dist/key-management.test.js",
    "test:integration": "pnpm -w build --filter @prontiq/control-plane... && node --test dist/provisioning.integration.test.js dist/quota-email.integration.test.js dist/ses-feedback.integration.test.js dist/lago-event-forwarder.integration.test.js dist/lago-webhook-reconciliation.integration.test.js",
    "repair:commercial-identity": "pnpm -w build --filter @prontiq/control-plane... && node dist/commercial-identity-repair.js",
    "lago:smoke:event": "pnpm -w build --filter @prontiq/control-plane... && node dist/lago-live-smoke.js",
    "lint": "eslint src/",
    "clean": "node ../../scripts/ts-package-build.mjs clean"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/client-sesv2": "^3.1037.0",
    "@aws-sdk/client-sqs": "^3.1037.0",
    "@aws-sdk/lib-dynamodb": "^3.1037.0",
    "@clerk/backend": "^3.3.0",
    "@prontiq/observability": "workspace:*",
    "@prontiq/shared": "workspace:*",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0"
  }
}
