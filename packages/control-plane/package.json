{
  "name": "@prontiq/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./provisioning": {
      "import": "./dist/provisioning.js",
      "types": "./dist/provisioning.d.ts"
    },
    "./audit": {
      "import": "./dist/audit.js",
      "types": "./dist/audit.d.ts"
    },
    "./clerk": {
      "import": "./dist/clerk.js",
      "types": "./dist/clerk.d.ts"
    },
    "./stripe-billing": {
      "import": "./dist/stripe-billing.js",
      "types": "./dist/stripe-billing.d.ts"
    },
    "./billing-cron": {
      "import": "./dist/billing-cron.js",
      "types": "./dist/billing-cron.d.ts"
    },
    "./month-close": {
      "import": "./dist/month-close.js",
      "types": "./dist/month-close.d.ts"
    },
    "./customer-backfill": {
      "import": "./dist/customer-backfill.js",
      "types": "./dist/customer-backfill.d.ts"
    },
    "./lago-webhook-reconciliation": {
      "import": "./dist/lago-webhook-reconciliation.js",
      "types": "./dist/lago-webhook-reconciliation.d.ts"
    },
    "./account-billing": {
      "import": "./dist/account-billing.js",
      "types": "./dist/account-billing.d.ts"
    }
  },
  "scripts": {
    "build": "node ../../scripts/ts-package-build.mjs build",
    "typecheck": "node ../../scripts/ts-package-build.mjs typecheck",
    "test": "pnpm -w build --filter @prontiq/control-plane... && node --test dist/audit.test.js dist/email.test.js dist/ses-feedback.test.js dist/provisioning.test.js dist/customer-backfill.test.js dist/clerk.test.js dist/stripe-billing-email.test.js dist/billing-runtime-retirement.test.js dist/lago-event-forwarder.test.js dist/lago-webhook-reconciliation.test.js dist/lago-live-smoke.test.js dist/account-billing.test.js",
    "test:integration": "pnpm -w build --filter @prontiq/control-plane... && node --test dist/provisioning.integration.test.js dist/billing-cron.integration.test.js dist/month-close.integration.test.js dist/quota-email.integration.test.js dist/ses-feedback.integration.test.js dist/lago-event-forwarder.integration.test.js dist/lago-webhook-reconciliation.integration.test.js",
    "backfill:customers": "pnpm -w build --filter @prontiq/control-plane... && node dist/customer-backfill.js",
    "lago:smoke:event": "pnpm -w build --filter @prontiq/control-plane... && node dist/lago-live-smoke.js",
    "lint": "eslint src/",
    "clean": "node ../../scripts/ts-package-build.mjs clean"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/client-sesv2": "^3.1037.0",
    "@aws-sdk/client-sqs": "^3.1037.0",
    "@aws-sdk/lib-dynamodb": "^3.1037.0",
    "@clerk/backend": "^3.3.0",
    "@prontiq/observability": "workspace:*",
    "@prontiq/shared": "workspace:*",
    "stripe": "^22.0.2",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0"
  }
}
