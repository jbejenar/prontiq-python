{
  "name": "@prontiq/observability",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node ../../scripts/ts-package-build.mjs build",
    "typecheck": "node ../../scripts/ts-package-build.mjs typecheck",
    "test": "pnpm -w build --filter @prontiq/observability... && node ../../scripts/run-node-tests.mjs dist/**/*.test.js",
    "lint": "eslint src/",
    "clean": "node ../../scripts/ts-package-build.mjs clean"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.1.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/instrumentation-aws-sdk": "^0.61.0",
    "@opentelemetry/instrumentation-http": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-node": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
