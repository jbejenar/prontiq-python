{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "prontiq",
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#22d3ee",
    "light": "#34d399",
    "dark": "#0D9373"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "guides/introduction",
              "guides/quickstart",
              "guides/authentication",
              "guides/credits",
              "guides/rate-limits"
            ]
          },
          {
            "group": "Address API",
            "pages": [
              "guides/address/overview",
              "guides/address/autocomplete",
              "guides/address/validate",
              "guides/address/enrich",
              "guides/address/reverse",
              "guides/address/lookups"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "guides/sdks/typescript",
              "guides/sdks/python"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Address API",
            "pages": [
              "api-reference/autocomplete",
              "api-reference/validate",
              "api-reference/enrich",
              "api-reference/reverse",
              "api-reference/postcode-lookup",
              "api-reference/suburb-lookup"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "api-reference/account-setup"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "mode": "simple"
    },
    "auth": {
      "method": "key",
      "name": "X-Api-Key"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/guides/introduction"
    }
  ],
  "feedback": {
    "thumbsRating": true
  }
}
