{
  "name": "@prontiq/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./content": {
      "import": "./dist/content.js",
      "types": "./dist/content.d.ts"
    },
    "./keys": {
      "import": "./dist/keys.js",
      "types": "./dist/keys.d.ts"
    }
  },
  "scripts": {
    "build": "node ../../scripts/ts-package-build.mjs build",
    "typecheck": "tsc --noEmit",
    "test": "pnpm -w build --filter @prontiq/shared... && node --test 'dist/**/*.test.js'",
    "lint": "eslint src/",
    "clean": "node ../../scripts/ts-package-build.mjs clean"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
